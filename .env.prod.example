# Django
SECRET_KEY=your-super-secret-key-change-in-production
ALLOWED_HOSTS=mystudy.com,www.mystudy.com,localhost

# Database (PostgreSQL)
DB_NAME=driving_study
DB_USER=driving_user
DB_PASSWORD=strong-password-here

# CORS
CORS_ALLOWED_ORIGINS=https://mystudy.com,https://www.mystudy.com

# Email (Yandex example)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.yandex.ru
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_HOST_USER=noreply@mystudy.com
EMAIL_HOST_PASSWORD=email-password-here
DEFAULT_FROM_EMAIL=noreply@mystudy.com

# S3 Storage (Optional - for media/static files)
# If not set, local volumes will be used
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=my-driving-study-media
# AWS_S3_REGION_NAME=eu-central-1

# Sentry (Error tracking - Optional)
# SENTRY_DSN=https://key@oXXXX.ingest.sentry.io/XXXX

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
